#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() 
{
    char ch;
    int MAX_LEN;
    char s[MAX_LEN];
    char sen[MAX_LEN];
    scanf("%c",&ch);
    printf("%c\n",ch);
    scanf("\n");
    scanf("%[^\n]%*c", s);
    printf("%s\n",s);
    scanf("\n");
    scanf("%[^\n]%*c", sen);
    printf("%s",sen); 
    return 0;
}
