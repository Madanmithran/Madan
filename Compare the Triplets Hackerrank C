#include <stdio.h>
#include <stdlib.h>

int* compareTriplets(int a_count, int* a, int b_count, int* b, int* result_count) {
    
    *result_count = 2;
    int* result = (int*)malloc(2 * sizeof(int));
    
    int alice_score = 0;
    int bob_score = 0;

    for (int i = 0; i < 3; i++) {
        if (a[i] > b[i]) {
            alice_score++;
        } else if (a[i] < b[i]) {
            bob_score++;
        }
        
    }

    result[0] = alice_score;
    result[1] = bob_score;

    return result;
}

int main() {
    int a[3], b[3];


    for (int i = 0; i < 3; i++) {
        scanf("%d", &a[i]);
    }

    for (int i = 0; i < 3; i++) {
        scanf("%d", &b[i]);
    }

    int result_count;
    int* result = compareTriplets(3, a, 3, b, &result_count);

  
    printf("%d %d\n", result[0], result[1]);

    free(result);

    return 0;
}
