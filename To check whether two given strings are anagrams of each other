#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char str1[1000], str2[1000];
    int freq1[26] = {0}, freq2[26] = {0};
    int i;

    fgets(str1, sizeof(str1), stdin);
    fgets(str2, sizeof(str2), stdin);

  
    int len1 = 0;
    for (i = 0; str1[i] != '\0'; i++) {
        if (isalpha(str1[i])) {
            str1[len1++] = tolower(str1[i]);
        }
    }
    str1[len1] = '\0';

    int len2 = 0;
    for (i = 0; str2[i] != '\0'; i++) {
        if (isalpha(str2[i])) {
            str2[len2++] = tolower(str2[i]);
        }
    }
    str2[len2] = '\0';
    
    if (strlen(str1) != strlen(str2)) {
        printf("Not Anagrams\n");
        return 0;
    }

    for (i = 0; str1[i] != '\0'; i++) {
        freq1[str1[i] - 'a']++;
    }

    for (i = 0; str2[i] != '\0'; i++) {
        freq2[str2[i] - 'a']++;
    }

    for (i = 0; i < 26; i++) {
        if (freq1[i] != freq2[i]) {
            printf("Not Anagrams\n");
            return 0;
        }
    }

    printf("Anagrams\n");

    return 0;
}
