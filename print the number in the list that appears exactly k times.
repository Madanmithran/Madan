#include <stdio.h>
#include <stdlib.h>

int main() {
    int arr[100];
    int k;
    int num, count, i, j;


    i = 0;
    while (scanf("%d", &num) ==  1) {
        arr[i++] = num;
    }

  
    rewind(stdin);
    scanf("%*[^\n]%*c"); 
    scanf("%d", &k);

 
    for (i = 0; i < (int)(sizeof(arr) / sizeof(arr[0])); i++) {
      if (arr[i] == 0 && i > 0) { 
        break;
      }
        count = 0;
        for (j = 0; j < (int)(sizeof(arr) / sizeof(arr[0])); j++) {
          if (arr[j] == 0 && j > 0) { 
            break;
          }
            if (arr[i] == arr[j]) {
                count++;
            }
        }
        if (count == k) {
            printf("%d\n", arr[i]);
            return 0;
        }
    }

    return 0;
}
