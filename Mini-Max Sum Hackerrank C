#include <stdio.h>

void miniMaxSum(int* arr) {
    long long total_sum = 0;
    int min = arr[0];
    int max = arr[0];

    for (int i = 0; i < 5; i++) {
        
        total_sum += arr[i];
        
       
        if (arr[i] < min) {
            min = arr[i];
        }
        
        
        if (arr[i] > max) {
            max = arr[i];
        }
    }

   
    printf("%lld %lld\n", total_sum - max, total_sum - min);
}

int main() {
    int arr[5];
    for (int i = 0; i < 5; i++) {
        if (scanf("%d", &arr[i]) != 1) break;
    }

    miniMaxSum(arr);

    return 0;
}
