int main() {

int n;
scanf("%d", &n);

int size=(2*n-1);

for(int i=0;i<(2*n-1);i++){
    for(int j=0;j<(2*n-1);j++){
        int top=i;
        int left=j;
        int right=(size-1)-j;
        int bottom=(size-1)-i;

        int min_dist=top;
        if(bottom < min_dist){min_dist=bottom;}
        if(left < min_dist){min_dist=left;}
        if(right < min_dist){min_dist=right;}
        printf("%d\t",n-min_dist);
    }
    printf("\n");
}
return 0;
}
