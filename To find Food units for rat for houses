#include <stdio.h>
int f(int r,int u ,int arr[50] ,int n)
{
int i;
int tf=0;
int ru=r*u;
if(arr==NULL)
    return -1;
for(i=0;i<n;i++)
{
    tf+=arr[i];

if(tf>=ru)
    return i+1;
}
return 0;
}



int main()
{
    int r,u,ru,n,i,arr[50],result;
    printf("Enter no of rats : ");
    scanf("%d",&r);
    printf("Enter no of units per rat : ");
    scanf("%d",&u);
    ru=r*u;
    printf("Enter no of houses : ");
    scanf("%d",&n);
    printf("Enter no of units per houses : \n");
    for(i=0;i<n;i++)
    {
        printf("\nHouse no %d : ",i+1);
        scanf("%d",&arr[i]);
    }
result = f(r,u,arr,n);
printf("\noutput : %d ",result);
return 0;
}
