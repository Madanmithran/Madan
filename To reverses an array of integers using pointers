#include <stdio.h>
int main(void) {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[1000];            
    for (int i = 0; i < n; ++i) {
        if (scanf("%d", arr + i) != 1) return 0; 
    }

    int *left = arr;
    int *right = arr + n - 1;
    while (left < right) {
        int tmp = *left;
        *left = *right;
        *right = tmp;
        left++;
        right--;
    }
    for (int i = 0; i < n; ++i) {
        if (i) printf(" ");
        printf("%d", *(arr + i)); 
    }
    printf("\n");
    return 0;
}

