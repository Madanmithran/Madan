#include <stdio.h>
#include <string.h>
#define NAME 50 
struct Employee {
    int id;
    char name[NAME];
    float salary;
};
int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    struct Employee emp;
    struct Employee best;
    int i;
    if (n <= 0) return 0;
    if (scanf("%d %50s %f", &emp.id, emp.name, &emp.salary) != 3) return 0;
    best = emp;

    for (i = 1; i < n; i++) {
        if (scanf("%d %50s %f", &emp.id, emp.name, &emp.salary) != 3) break;
        if (emp.salary > best.salary) {
            best = emp;
        }
    }

    printf("%d %s %.2f\n", best.id, best.name, best.salary);
    return 0;
}
